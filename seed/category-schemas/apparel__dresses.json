{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/apparel_dresses/v1",
  "type": "object",
  "tier": "authoritative",
  "required": [
    "product_name",
    "description",
    "price_usd"
  ],
  "properties": {
    "product_name": {
      "type": "string",
      "description": "Name of the product"
    },
    "description": {
      "type": "string",
      "description": "Description of the product"
    },
    "price_usd": {
      "type": "number",
      "description": "Price of the product in USD"
    },
    "size": {
      "type": "string",
      "enum": [
        "xs",
        "s",
        "m",
        "l",
        "xl",
        "xxl"
      ]
    },
    "color": {
      "type": "string",
      "description": "Color of the product"
    },
    "material": {
      "type": "string",
      "enum": [
        "cotton",
        "polyester",
        "silk",
        "wool"
      ]
    },
    "length_inches": {
      "type": "number",
      "minimum": 20,
      "maximum": 60
    },
    "waist_size_inches": {
      "type": "number",
      "minimum": 20,
      "maximum": 40
    },
    "season_rating": {
      "type": "string",
      "enum": [
        "spring",
        "summer",
        "autumn",
        "winter"
      ]
    }
  },
  "additionalProperties": true
}

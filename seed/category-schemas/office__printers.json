{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/office_printers/v1",
  "type": "object",
  "tier": "inferred",
  "required": [
    "product_name",
    "model_number"
  ],
  "properties": {
    "product_name": {
      "type": "string",
      "description": "Name of the product"
    },
    "model_number": {
      "type": "string",
      "description": "Model number of the product"
    },
    "printer_type": {
      "type": "string",
      "enum": [
        "laser",
        "inkjet",
        "dot_matrix"
      ]
    },
    "print_resolution_dpi": {
      "type": "integer",
      "minimum": 100,
      "maximum": 1200
    },
    "paper_tray_capacity_sheets": {
      "type": "integer",
      "minimum": 50,
      "maximum": 500
    },
    "print_speed_ppm": {
      "type": "number",
      "minimum": 1,
      "maximum": 100
    },
    "connectivity_options": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "usb",
          "ethernet",
          "wireless",
          "bluetooth"
        ]
      }
    }
  },
  "additionalProperties": true
}

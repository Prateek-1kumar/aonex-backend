{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/auto_dash_cams/v1",
  "type": "object",
  "required": [
    "brand",
    "model",
    "resolution"
  ],
  "properties": {
    "brand": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "resolution": {
      "type": "string",
      "enum": [
        "720p",
        "1080p",
        "1440p",
        "4K"
      ]
    },
    "field_of_view": {
      "type": "number",
      "unit": "degrees",
      "minimum": 120,
      "maximum": 170
    },
    "night_vision": {
      "type": "boolean"
    },
    "wdr": {
      "type": "boolean"
    },
    "gps": {
      "type": "boolean"
    },
    "g_sensor": {
      "type": "boolean"
    },
    "screen_size_inches": {
      "type": "number",
      "unit": "inches",
      "minimum": 2,
      "maximum": 3
    },
    "packed_weight_grams": {
      "type": "number",
      "unit": "grams",
      "minimum": 100,
      "maximum": 500
    },
    "ram_gb": {
      "type": "number",
      "unit": "GB",
      "minimum": 1,
      "maximum": 8
    },
    "battery_mah": {
      "type": "number",
      "unit": "mAh",
      "minimum": 2000,
      "maximum": 5000
    },
    "canopy_diameter_cm": {
      "type": "number",
      "unit": "cm",
      "minimum": 10,
      "maximum": 20
    },
    "micro_sd_support": {
      "type": "boolean"
    },
    "waterproof_rating": {
      "type": "string",
      "enum": [
        "IP67",
        "IP68",
        "IP69K"
      ]
    },
    "operating_temperature": {
      "type": "string",
      "enum": [
        "-20°C to 60°C",
        "-20°C to 70°C"
      ]
    },
    "storage_capacity_gb": {
      "type": "number",
      "unit": "GB",
      "minimum": 16,
      "maximum": 256
    },
    "video_format": {
      "type": "string",
      "enum": [
        "H.264",
        "H.265"
      ]
    },
    "warranty_years": {
      "type": "number",
      "unit": "years",
      "minimum": 1,
      "maximum": 3
    },
    "warranty_days": {
      "type": "number",
      "unit": "days",
      "minimum": 30,
      "maximum": 365
    }
  },
  "additionalProperties": true,
  "tier": "inferred"
}

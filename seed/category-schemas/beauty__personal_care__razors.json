{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/beauty_personal_care_razors/v1",
  "type": "object",
  "required": [
    "product_name",
    "brand",
    "model_number"
  ],
  "properties": {
    "product_name": {
      "type": "string",
      "description": "Name of the product"
    },
    "brand": {
      "type": "string",
      "description": "Brand of the product"
    },
    "model_number": {
      "type": "string",
      "description": "Model number of the product"
    },
    "blade_count": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of blades in the razor"
    },
    "handle_length_inches": {
      "type": "number",
      "minimum": 0,
      "description": "Length of the handle in inches"
    },
    "handle_material": {
      "type": "string",
      "enum": [
        "plastic",
        "metal",
        "wood",
        "bamboo"
      ],
      "description": "Material of the handle"
    },
    "razor_type": {
      "type": "string",
      "enum": [
        "safety",
        "straight",
        "cartridge",
        "electric"
      ],
      "description": "Type of razor"
    }
  },
  "additionalProperties": true,
  "tier": "inferred"
}

{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/electronics_cameras/v1",
  "type": "object",
  "tier": "authoritative",
  "required": [
    "product_name",
    "model_number",
    "manufacturer"
  ],
  "properties": {
    "product_name": {
      "type": "string",
      "description": "Name of the camera product"
    },
    "model_number": {
      "type": "string",
      "description": "Model number of the camera"
    },
    "manufacturer": {
      "type": "string",
      "description": "Manufacturer of the camera"
    },
    "megapixels": {
      "type": "integer",
      "description": "Number of megapixels of the camera"
    },
    "screen_size_inches": {
      "type": "number",
      "minimum": 1,
      "maximum": 10,
      "description": "Screen size of the camera in inches"
    },
    "weight_grams": {
      "type": "number",
      "minimum": 100,
      "maximum": 2000,
      "description": "Weight of the camera in grams"
    },
    "battery_mah": {
      "type": "integer",
      "minimum": 500,
      "maximum": 2000,
      "description": "Battery capacity of the camera in milliampere-hours"
    },
    "storage_gb": {
      "type": "integer",
      "minimum": 4,
      "maximum": 128,
      "description": "Internal storage capacity of the camera in gigabytes"
    },
    "video_resolution": {
      "type": "string",
      "enum": [
        "hd",
        "full_hd",
        "4k",
        "8k"
      ],
      "description": "Maximum video resolution of the camera"
    }
  },
  "additionalProperties": true
}

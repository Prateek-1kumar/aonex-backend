{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/outdoor_sports_bicycles/v1",
  "type": "object",
  "tier": "authoritative",
  "required": [
    "frame_size_cm",
    "wheel_size_inches",
    "gear_count",
    "bike_type"
  ],
  "properties": {
    "frame_size_cm": {
      "type": "number",
      "minimum": 30,
      "maximum": 70
    },
    "wheel_size_inches": {
      "type": "number",
      "minimum": 12,
      "maximum": 29
    },
    "gear_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 33
    },
    "bike_type": {
      "type": "string",
      "enum": [
        "road",
        "mountain",
        "hybrid",
        "gravel",
        "bmx",
        "electric",
        "cargo",
        "folding"
      ]
    },
    "frame_material": {
      "type": "string",
      "enum": [
        "aluminum",
        "carbon_fiber",
        "steel",
        "titanium",
        "chromoly"
      ]
    },
    "brake_type": {
      "type": "string",
      "enum": [
        "disc_hydraulic",
        "disc_mechanical",
        "rim",
        "coaster"
      ]
    },
    "suspension": {
      "type": "string",
      "enum": [
        "hardtail",
        "full_suspension",
        "rigid"
      ]
    },
    "weight_kg": {
      "type": "number",
      "minimum": 5,
      "maximum": 40
    }
  },
  "additionalProperties": true
}

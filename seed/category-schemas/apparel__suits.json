{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/apparel_suits/v1",
  "type": "object",
  "required": [
    "product_name",
    "description",
    "price_usd"
  ],
  "properties": {
    "product_name": {
      "type": "string",
      "description": "Name of the product"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the product"
    },
    "price_usd": {
      "type": "number",
      "description": "Price of the product in USD"
    },
    "size": {
      "type": "string",
      "enum": [
        "xs",
        "s",
        "m",
        "l",
        "xl",
        "xxl"
      ]
    },
    "color": {
      "type": "string",
      "description": "Color of the product"
    },
    "fabric_type": {
      "type": "string",
      "enum": [
        "wool",
        "cotton",
        "polyester",
        "linen"
      ]
    },
    "chest_circumference_inches": {
      "type": "number",
      "minimum": 30,
      "maximum": 50
    },
    "waist_circumference_inches": {
      "type": "number",
      "minimum": 20,
      "maximum": 40
    },
    "length_inches": {
      "type": "number",
      "minimum": 20,
      "maximum": 40
    }
  },
  "tier": "inferred",
  "additionalProperties": true
}

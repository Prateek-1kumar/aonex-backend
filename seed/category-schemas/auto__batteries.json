{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/auto_batteries/v1",
  "type": "object",
  "tier": "inferred",
  "required": [
    "battery_type",
    "cold_cranking_amps",
    "reserve_capacity_minutes",
    "battery_group_size"
  ],
  "properties": {
    "battery_type": {
      "type": "string",
      "enum": [
        "flooded",
        "absorbed_glass_mat",
        "lithium_ion"
      ]
    },
    "cold_cranking_amps": {
      "type": "integer",
      "minimum": 100,
      "maximum": 1000
    },
    "reserve_capacity_minutes": {
      "type": "integer",
      "minimum": 60,
      "maximum": 180
    },
    "battery_group_size": {
      "type": "string",
      "enum": [
        "51",
        "51r",
        "65",
        "75",
        "34",
        "34r",
        "48",
        "49",
        "55",
        "56",
        "57",
        "58",
        "59",
        "60",
        "61",
        "62",
        "63",
        "64",
        "65",
        "66",
        "67",
        "69",
        "70",
        "71",
        "72",
        "73",
        "74",
        "75",
        "76",
        "77",
        "78",
        "79",
        "80",
        "82",
        "85",
        "86",
        "87",
        "88",
        "89",
        "90",
        "91",
        "92",
        "93",
        "94",
        "95",
        "96",
        "97",
        "98",
        "99"
      ]
    },
    "terminal_type": {
      "type": "string",
      "enum": [
        "top_post",
        "side_post",
        "dual_terminal"
      ]
    },
    "voltage": {
      "type": "integer",
      "enum": [
        6,
        12
      ]
    },
    "capacity_ah": {
      "type": "number",
      "minimum": 20,
      "maximum": 200
    },
    "weight_lbs": {
      "type": "number",
      "minimum": 20,
      "maximum": 100
    },
    "length_inches": {
      "type": "number",
      "minimum": 6,
      "maximum": 15
    },
    "width_inches": {
      "type": "number",
      "minimum": 3,
      "maximum": 7
    },
    "height_inches": {
      "type": "number",
      "minimum": 5,
      "maximum": 10
    }
  },
  "additionalProperties": true
}

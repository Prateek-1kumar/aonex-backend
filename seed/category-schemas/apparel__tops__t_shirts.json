{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/apparel_tops_t_shirts/v1",
  "type": "object",
  "tier": "authoritative",
  "required": [
    "product_name",
    "description",
    "price_usd"
  ],
  "properties": {
    "product_name": {
      "type": "string",
      "description": "Name of the product"
    },
    "description": {
      "type": "string",
      "description": "Description of the product"
    },
    "price_usd": {
      "type": "number",
      "description": "Price of the product in USD"
    },
    "size": {
      "type": "string",
      "enum": [
        "xs",
        "s",
        "m",
        "l",
        "xl",
        "xxl"
      ],
      "description": "Size of the t-shirt"
    },
    "color": {
      "type": "string",
      "description": "Color of the t-shirt"
    },
    "material": {
      "type": "string",
      "enum": [
        "cotton",
        "polyester",
        "blend"
      ],
      "description": "Material of the t-shirt"
    },
    "length_inches": {
      "type": "number",
      "minimum": 20,
      "maximum": 30,
      "description": "Length of the t-shirt in inches"
    },
    "chest_circumference_inches": {
      "type": "number",
      "minimum": 30,
      "maximum": 50,
      "description": "Chest circumference of the t-shirt in inches"
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/electronics_televisions/v1",
  "type": "object",
  "tier": "authoritative",
  "required": [
    "screen_size_inches",
    "resolution",
    "refresh_rate_hz"
  ],
  "properties": {
    "screen_size_inches": {
      "type": "number",
      "minimum": 10,
      "maximum": 100
    },
    "resolution": {
      "type": "string",
      "enum": [
        "hd",
        "full_hd",
        "4k",
        "8k"
      ]
    },
    "refresh_rate_hz": {
      "type": "integer",
      "minimum": 60,
      "maximum": 240
    },
    "ram_gb": {
      "type": "integer",
      "minimum": 1,
      "maximum": 16
    },
    "storage_gb": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000
    },
    "packed_weight_grams": {
      "type": "number",
      "minimum": 1000,
      "maximum": 50000
    },
    "smart_tv": {
      "type": "boolean"
    },
    "operating_system": {
      "type": "string",
      "enum": [
        "android",
        "tizen",
        "webos"
      ]
    }
  },
  "additionalProperties": true
}

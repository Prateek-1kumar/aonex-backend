{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/electronics_televisions/v1",
  "type": "object",
  "tier": "authoritative",
  "required": [
    "screen_size_inches",
    "resolution",
    "display_type",
    "refresh_rate_hz"
  ],
  "properties": {
    "screen_size_inches": {
      "type": "number",
      "minimum": 19,
      "maximum": 110
    },
    "resolution": {
      "type": "string",
      "enum": [
        "720p",
        "1080p",
        "1440p",
        "4k",
        "8k"
      ]
    },
    "display_type": {
      "type": "string",
      "enum": [
        "led",
        "oled",
        "qled",
        "mini_led",
        "micro_led"
      ]
    },
    "refresh_rate_hz": {
      "type": "integer",
      "minimum": 60,
      "maximum": 240
    },
    "smart_tv": {
      "type": "boolean"
    },
    "operating_system": {
      "type": "string",
      "enum": [
        "android_tv",
        "tizen",
        "webos",
        "roku",
        "fire_tv",
        "proprietary"
      ]
    },
    "ram_gb": {
      "type": "integer",
      "minimum": 1,
      "maximum": 16
    },
    "storage_gb": {
      "type": "integer",
      "minimum": 8,
      "maximum": 256
    },
    "hdmi_ports": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    },
    "hdr_support": {
      "type": "string",
      "enum": [
        "hdr10",
        "hdr10+",
        "dolby_vision",
        "hlg",
        "none"
      ]
    }
  },
  "additionalProperties": true
}

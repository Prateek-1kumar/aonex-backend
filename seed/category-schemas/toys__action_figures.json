{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/toys/action_figures/v1",
  "type": "object",
  "required": [
    "product_name",
    "manufacturer",
    "recommended_age_range"
  ],
  "properties": {
    "product_name": {
      "type": "string",
      "description": "Name of the action figure"
    },
    "manufacturer": {
      "type": "string",
      "description": "Manufacturer of the action figure"
    },
    "recommended_age_range": {
      "type": "string",
      "description": "Recommended age range for the action figure",
      "enum": [
        "3+ years",
        "6+ years",
        "12+ years"
      ]
    },
    "height_inches": {
      "type": "number",
      "description": "Height of the action figure in inches",
      "minimum": 1,
      "maximum": 24
    },
    "weight_grams": {
      "type": "number",
      "description": "Weight of the action figure in grams",
      "minimum": 10,
      "maximum": 1000
    },
    "material": {
      "type": "string",
      "description": "Material of the action figure",
      "enum": [
        "plastic",
        "vinyl",
        "metal"
      ]
    },
    "character_name": {
      "type": "string",
      "description": "Name of the character represented by the action figure"
    }
  },
  "additionalProperties": true,
  "tier": "inferred"
}

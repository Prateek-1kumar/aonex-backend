{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/beauty_makeup_lipstick/v1",
  "type": "object",
  "tier": "inferred",
  "required": [
    "product_name",
    "brand",
    "price_usd"
  ],
  "properties": {
    "product_name": {
      "type": "string",
      "description": "Name of the lipstick product"
    },
    "brand": {
      "type": "string",
      "description": "Brand of the lipstick"
    },
    "price_usd": {
      "type": "number",
      "description": "Price of the lipstick in USD"
    },
    "finish_type": {
      "type": "string",
      "enum": [
        "matte",
        "satin",
        "glossy",
        "sheer"
      ],
      "description": "Finish type of the lipstick"
    },
    "color_shade": {
      "type": "string",
      "description": "Color shade of the lipstick"
    },
    "net_weight_grams": {
      "type": "number",
      "minimum": 0,
      "description": "Net weight of the lipstick in grams"
    }
  },
  "additionalProperties": true
}

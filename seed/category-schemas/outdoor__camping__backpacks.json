{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/outdoor_camping_backpacks/v1",
  "type": "object",
  "tier": "authoritative",
  "required": [
    "capacity_liters",
    "frame_type",
    "weight_grams"
  ],
  "properties": {
    "capacity_liters": {
      "type": "number",
      "minimum": 5,
      "maximum": 120
    },
    "frame_type": {
      "type": "string",
      "enum": [
        "internal",
        "external",
        "frameless"
      ]
    },
    "weight_grams": {
      "type": "number",
      "minimum": 200,
      "maximum": 5000
    },
    "material": {
      "type": "string",
      "enum": [
        "nylon",
        "polyester",
        "dyneema",
        "canvas",
        "ripstop_nylon"
      ]
    },
    "gender_fit": {
      "type": "string",
      "enum": [
        "men",
        "women",
        "unisex"
      ]
    },
    "torso_length_cm": {
      "type": "number",
      "minimum": 35,
      "maximum": 65
    },
    "waterproof_rating_mm": {
      "type": "number",
      "minimum": 0,
      "maximum": 5000
    },
    "hip_belt": {
      "type": "boolean"
    },
    "rain_cover_included": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}

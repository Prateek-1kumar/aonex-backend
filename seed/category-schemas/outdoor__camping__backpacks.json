{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/outdoor_camping_backpacks/v1",
  "type": "object",
  "required": [
    "brand",
    "model",
    "capacity_liters"
  ],
  "properties": {
    "brand": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "capacity_liters": {
      "type": "number",
      "minimum": 10,
      "maximum": 100
    },
    "weight_grams": {
      "type": "number",
      "minimum": 500,
      "maximum": 3000
    },
    "season_rating": {
      "type": "string",
      "enum": [
        "3-season",
        "4-season"
      ]
    },
    "material": {
      "type": "string",
      "enum": [
        "nylon",
        "polyester",
        "canvas"
      ]
    },
    "torso_length_inches": {
      "type": "number",
      "minimum": 15,
      "maximum": 24
    },
    "hip_belt_size_inches": {
      "type": "number",
      "minimum": 25,
      "maximum": 40
    }
  },
  "tier": "authoritative",
  "additionalProperties": true
}

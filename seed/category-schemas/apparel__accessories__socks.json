{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/apparel_accessories_socks/v1",
  "type": "object",
  "tier": "inferred",
  "required": [
    "product_name",
    "description"
  ],
  "properties": {
    "product_name": {
      "type": "string",
      "description": "Name of the product"
    },
    "description": {
      "type": "string",
      "description": "Short description of the product"
    },
    "material": {
      "type": "string",
      "enum": [
        "cotton",
        "polyester",
        "wool",
        "nylon",
        "spandex"
      ]
    },
    "size": {
      "type": "string",
      "enum": [
        "small",
        "medium",
        "large",
        "x_large"
      ]
    },
    "color": {
      "type": "string"
    },
    "length_inches": {
      "type": "number",
      "minimum": 0
    },
    "calf_circumference_inches": {
      "type": "number",
      "minimum": 0
    },
    "weight_grams": {
      "type": "number",
      "minimum": 0
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/outdoor_camping_tents/v1",
  "type": "object",
  "tier": "authoritative",
  "required": [
    "capacity_persons",
    "season_rating",
    "packed_weight_grams",
    "floor_area_sq_m",
    "waterproof_rating_mm"
  ],
  "properties": {
    "capacity_persons": {
      "type": "integer",
      "minimum": 1,
      "maximum": 12
    },
    "season_rating": {
      "type": "string",
      "enum": [
        "1-season",
        "2-season",
        "3-season",
        "4-season"
      ]
    },
    "packed_weight_grams": {
      "type": "number",
      "minimum": 300,
      "maximum": 20000
    },
    "floor_area_sq_m": {
      "type": "number",
      "minimum": 0.5,
      "maximum": 30
    },
    "waterproof_rating_mm": {
      "type": "number",
      "minimum": 0,
      "maximum": 10000
    },
    "setup_type": {
      "type": "string",
      "enum": [
        "freestanding",
        "semi_freestanding",
        "non_freestanding"
      ]
    },
    "pole_material": {
      "type": "string",
      "enum": [
        "aluminum",
        "fiberglass",
        "carbon_fiber",
        "steel"
      ]
    },
    "inner_height_cm": {
      "type": "number",
      "minimum": 50,
      "maximum": 250
    },
    "door_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 6
    },
    "vestibule_area_sq_m": {
      "type": "number",
      "minimum": 0,
      "maximum": 10
    }
  },
  "additionalProperties": true
}

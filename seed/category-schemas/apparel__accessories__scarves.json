{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/apparel_accessories_scarves/v1",
  "type": "object",
  "tier": "inferred",
  "required": [
    "product_name",
    "material",
    "color"
  ],
  "properties": {
    "product_name": {
      "type": "string",
      "description": "Name of the product"
    },
    "material": {
      "type": "string",
      "enum": [
        "cotton",
        "silk",
        "wool",
        "polyester",
        "cashmere"
      ]
    },
    "color": {
      "type": "string",
      "enum": [
        "red",
        "blue",
        "green",
        "yellow",
        "black",
        "white"
      ]
    },
    "size": {
      "type": "string",
      "enum": [
        "small",
        "medium",
        "large"
      ]
    },
    "length_inches": {
      "type": "number",
      "minimum": 20,
      "maximum": 90
    },
    "width_inches": {
      "type": "number",
      "minimum": 5,
      "maximum": 40
    },
    "weight_grams": {
      "type": "number",
      "minimum": 50,
      "maximum": 500
    },
    "season_rating": {
      "type": "string",
      "enum": [
        "spring",
        "summer",
        "autumn",
        "winter"
      ]
    }
  },
  "additionalProperties": true
}

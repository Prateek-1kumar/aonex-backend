{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/office_monitors/v1",
  "type": "object",
  "tier": "inferred",
  "required": [
    "screen_size_inches",
    "resolution",
    "refresh_rate_hz"
  ],
  "properties": {
    "screen_size_inches": {
      "type": "number",
      "minimum": 13,
      "maximum": 49
    },
    "resolution": {
      "type": "string",
      "enum": [
        "hd",
        "full_hd",
        "qhd",
        "uhd",
        "4k"
      ]
    },
    "refresh_rate_hz": {
      "type": "integer",
      "minimum": 60,
      "maximum": 240
    },
    "response_time_ms": {
      "type": "integer",
      "minimum": 1,
      "maximum": 16
    },
    "aspect_ratio": {
      "type": "string",
      "enum": [
        "16:9",
        "16:10",
        "4:3"
      ]
    },
    "display_type": {
      "type": "string",
      "enum": [
        "lcd",
        "led",
        "oled"
      ]
    },
    "connectivity": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "vga",
          "dvi",
          "hdmi",
          "displayport",
          "usb"
        ]
      }
    }
  },
  "additionalProperties": true
}

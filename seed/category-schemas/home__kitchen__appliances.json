{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/home_kitchen_appliances/v1",
  "type": "object",
  "tier": "authoritative",
  "required": [
    "appliance_type",
    "wattage_w"
  ],
  "properties": {
    "appliance_type": {
      "type": "string",
      "enum": [
        "refrigerator",
        "dishwasher",
        "oven",
        "microwave",
        "toaster",
        "blender",
        "food_processor",
        "coffee_maker",
        "air_fryer",
        "instant_pot",
        "stand_mixer",
        "juicer",
        "rice_cooker",
        "slow_cooker",
        "waffle_maker",
        "other"
      ]
    },
    "wattage_w": {
      "type": "number",
      "minimum": 10,
      "maximum": 10000
    },
    "capacity_liters": {
      "type": "number",
      "minimum": 0.1,
      "maximum": 1000
    },
    "color": {
      "type": "string",
      "enum": [
        "black",
        "white",
        "silver",
        "stainless_steel",
        "red",
        "other"
      ]
    },
    "voltage_v": {
      "type": "integer",
      "minimum": 100,
      "maximum": 240
    },
    "smart_features": {
      "type": "boolean"
    },
    "energy_star_certified": {
      "type": "boolean"
    },
    "weight_kg": {
      "type": "number",
      "minimum": 0.1,
      "maximum": 200
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/home_furniture_mirrors/v1",
  "type": "object",
  "tier": "inferred",
  "required": [
    "product_name",
    "description"
  ],
  "properties": {
    "product_name": {
      "type": "string",
      "description": "Name of the product"
    },
    "description": {
      "type": "string",
      "description": "Short description of the product"
    },
    "frame_material": {
      "type": "string",
      "enum": [
        "wood",
        "metal",
        "plastic",
        "glass"
      ]
    },
    "mirror_shape": {
      "type": "string",
      "enum": [
        "round",
        "square",
        "rectangle",
        "oval"
      ]
    },
    "frame_width_inches": {
      "type": "number",
      "minimum": 0.1,
      "maximum": 10
    },
    "mirror_diameter_inches": {
      "type": "number",
      "minimum": 5,
      "maximum": 60
    },
    "weight_lbs": {
      "type": "number",
      "minimum": 1,
      "maximum": 50
    },
    "mounting_type": {
      "type": "string",
      "enum": [
        "wall_mounted",
        "tabletop",
        "floor_standing"
      ]
    }
  },
  "additionalProperties": true
}

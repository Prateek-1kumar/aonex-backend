{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/home_furniture_shelves/v1",
  "type": "object",
  "required": [
    "product_name",
    "description",
    "price_usd"
  ],
  "properties": {
    "product_name": {
      "type": "string",
      "description": "Name of the product"
    },
    "description": {
      "type": "string",
      "description": "Short description of the product"
    },
    "price_usd": {
      "type": "number",
      "description": "Price of the product in USD"
    },
    "shelf_material": {
      "type": "string",
      "enum": [
        "wood",
        "metal",
        "glass",
        "plastic"
      ]
    },
    "shelf_color": {
      "type": "string",
      "enum": [
        "black",
        "white",
        "brown",
        "gray"
      ]
    },
    "height_inches": {
      "type": "number",
      "minimum": 10,
      "maximum": 80
    },
    "width_inches": {
      "type": "number",
      "minimum": 10,
      "maximum": 80
    },
    "depth_inches": {
      "type": "number",
      "minimum": 5,
      "maximum": 20
    },
    "weight_lbs": {
      "type": "number",
      "minimum": 10,
      "maximum": 100
    }
  },
  "tier": "inferred",
  "additionalProperties": true
}

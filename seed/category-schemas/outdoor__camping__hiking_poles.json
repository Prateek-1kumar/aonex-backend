{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/outdoor_camping_hiking_poles/v1",
  "type": "object",
  "required": [
    "product_name",
    "product_description"
  ],
  "properties": {
    "product_name": {
      "type": "string"
    },
    "product_description": {
      "type": "string"
    },
    "weight_grams": {
      "type": "number",
      "minimum": 0
    },
    "collapsed_length_inches": {
      "type": "number",
      "minimum": 0
    },
    "extended_length_inches": {
      "type": "number",
      "minimum": 0
    },
    "material": {
      "type": "string",
      "enum": [
        "aluminum",
        "carbon_fiber",
        "steel"
      ]
    },
    "season_rating": {
      "type": "string",
      "enum": [
        "3-season",
        "4-season"
      ]
    }
  },
  "additionalProperties": true,
  "tier": "inferred"
}

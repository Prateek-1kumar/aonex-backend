{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/beauty_skincare_moisturizers/v1",
  "type": "object",
  "tier": "authoritative",
  "required": [
    "volume_ml",
    "skin_type",
    "spf"
  ],
  "properties": {
    "volume_ml": {
      "type": "number",
      "minimum": 5,
      "maximum": 500
    },
    "skin_type": {
      "type": "string",
      "enum": [
        "oily",
        "dry",
        "normal",
        "combination",
        "sensitive",
        "all"
      ]
    },
    "spf": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "moisturizer_type": {
      "type": "string",
      "enum": [
        "day",
        "night",
        "all_day"
      ]
    },
    "formulation": {
      "type": "string",
      "enum": [
        "cream",
        "lotion",
        "gel",
        "serum",
        "balm",
        "oil"
      ]
    },
    "fragrance_free": {
      "type": "boolean"
    },
    "hypoallergenic": {
      "type": "boolean"
    },
    "vegan": {
      "type": "boolean"
    },
    "key_ingredients": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}

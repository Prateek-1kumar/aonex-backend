{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/auto_floor_mats/v1",
  "type": "object",
  "tier": "inferred",
  "required": [
    "product_name",
    "material",
    "size_length_inches",
    "size_width_inches"
  ],
  "properties": {
    "product_name": {
      "type": "string"
    },
    "material": {
      "type": "string",
      "enum": [
        "rubber",
        "plastic",
        "carpet"
      ]
    },
    "size_length_inches": {
      "type": "number",
      "minimum": 10,
      "maximum": 60
    },
    "size_width_inches": {
      "type": "number",
      "minimum": 10,
      "maximum": 30
    },
    "color": {
      "type": "string",
      "enum": [
        "black",
        "gray",
        "beige",
        "brown"
      ]
    },
    "weight_ounces": {
      "type": "number",
      "minimum": 1,
      "maximum": 100
    }
  },
  "additionalProperties": true
}

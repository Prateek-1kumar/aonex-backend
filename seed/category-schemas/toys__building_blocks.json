{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "category_schemas/toys_building_blocks/v1",
  "type": "object",
  "tier": "inferred",
  "required": [
    "product_name",
    "description",
    "age_range"
  ],
  "properties": {
    "product_name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "age_range": {
      "type": "string",
      "enum": [
        "infant",
        "toddler",
        "preschool",
        "school_age"
      ]
    },
    "piece_count": {
      "type": "integer"
    },
    "weight_grams": {
      "type": "number"
    },
    "dimensions_inches": {
      "type": "object",
      "properties": {
        "length": {
          "type": "number"
        },
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        }
      }
    },
    "material": {
      "type": "string",
      "enum": [
        "plastic",
        "wood",
        "fabric"
      ]
    }
  },
  "additionalProperties": true
}

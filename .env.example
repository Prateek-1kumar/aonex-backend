# ============================================================
# Aonex backend — example env. Copy to .env (local) or pull
# from AWS SSM SecureString in staging/prod.
#
# Per HLD §22: secrets are KMS-encrypted. NEVER commit real
# values. The webhook secret rotation runbook expects
# NANGO_WEBHOOK_SECRET_NEXT to coexist during rotation.
# ============================================================

NODE_ENV=development
PORT=8787

# Postgres — RDS in prod, docker-compose in dev
DATABASE_URL=postgres://aonex:aonex@localhost:5432/aonex_dev

# Redis — ElastiCache in prod, docker-compose in dev
REDIS_URL=redis://localhost:6379

# Nango — Cloud (Starter) at launch per LLD §3 / ADR-001
# Set NANGO_HOST to a self-hosted URL when migrating off cloud.
NANGO_SECRET_KEY=change-me
NANGO_WEBHOOK_SECRET=change-me
# NANGO_WEBHOOK_SECRET_NEXT=  # populated only during rotation
# NANGO_HOST=https://api.nango.dev

# JWT — HS256, 256-bit secret (32 random bytes hex/base64)
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-32-bytes-min

# Observability (Phase 1)
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
